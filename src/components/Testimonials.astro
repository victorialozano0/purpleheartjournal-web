---
const testimonials = [
  {
    text: "Puse Epiphany, abrí la primera página y no pude parar de escribir. Es como si cada pregunta supiera exactamente lo que necesitaba soltar.",
    name: "Andrea",
    detail: "ARMY desde 2018",
    highlight: "no pude parar de escribir",
  },
  {
    text: "Puse Spring Day y abrí el capítulo de emociones. Lloré, escribí, y me sentí más liviana. Por fin un journal que entiende lo que es ser ARMY.",
    name: "Camila",
    detail: "ARMY — Colombia",
    highlight: "entiende lo que es ser ARMY",
  },
  {
    text: "El capítulo 'Soy parte de ARMY' me destruyó. Nunca había escrito sobre lo que BTS significa para mí. Este journal hits different.",
    name: "Valentina",
    detail: "ARMY — México",
    highlight: "hits different",
  },
];
---

<section class="bg-lavender-mist section-padding">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-8">
      <p class="section-intro">
        lo que dicen quienes ya escribieron
      </p>

      <h2 class="section-title text-text-deep">
        Esto pasa cuando empiezas a escribir.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {testimonials.map((t) => (
        <div class="card-testimonial">
          <!-- Quote icon -->
          <div>
            <svg class="w-7 h-7 text-purple-heart/25 mb-3" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z"/>
            </svg>
            <p class="font-body text-text-deep text-sm md:text-base leading-relaxed">
              {t.text}
            </p>
          </div>

          <!-- Author -->
          <div class="border-t border-soft-lilac/60 pt-3 mt-5">
            <p class="font-body font-bold text-text-deep text-sm">{t.name}</p>
            <p class="font-body text-text-muted text-xs">{t.detail}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
