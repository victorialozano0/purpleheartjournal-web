---
const year = new Date().getFullYear();
---

<footer class="bg-text-deep py-10 px-5">
  <div class="max-w-3xl mx-auto text-center">
    <p class="font-heading italic text-xl text-purple-heart mb-1">
      Purple Heart Journal
    </p>
    <p class="font-body text-xs text-soft-lilac/50 mb-6">
      Hecho por ARMY, para ARMY.
    </p>

    <!-- Social -->
    <div class="flex items-center justify-center gap-5 mb-6">
      <a
        href="https://www.tiktok.com/@purpleheart.journal"
        target="_blank"
        rel="noopener noreferrer"
        class="text-soft-lilac/50 hover:text-purple-heart transition-colors duration-200 cursor-pointer"
        aria-label="TikTok"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.88-2.88 2.89 2.89 0 012.88-2.88c.28 0 .56.04.82.11v-3.5a6.37 6.37 0 00-.82-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.75a8.18 8.18 0 004.76 1.52v-3.4a4.85 4.85 0 01-1-.18z"/>
        </svg>
      </a>
      <a
        href="https://www.instagram.com/purpleheartjournal.bts"
        target="_blank"
        rel="noopener noreferrer"
        class="text-soft-lilac/50 hover:text-purple-heart transition-colors duration-200 cursor-pointer"
        aria-label="Instagram"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
      </a>
    </div>

    <div class="border-t border-soft-lilac/10 pt-5">
      <p class="font-body text-[10px] text-soft-lilac/30">
        &copy; {year} Purple Heart Journal. Todos los derechos reservados.
        <br />
        Proyecto fan-made, independiente y no oficial. No afiliado a HYBE, BigHit o BTS.
      </p>
    </div>
  </div>
</footer>
